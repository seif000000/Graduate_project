{
    "rewrites": [
        {
            "source": "/api/v1/:path*",
            "destination": "/_backend/api/v1/:path*"
        }
    ],
    "experimentalServices": {
        "frontend": {
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_backend"
        }
    }
}
